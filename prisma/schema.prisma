// This is your Prisma schema file,

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// defining roles 
// this keeps  auth and authorization aligned 
enum UserRole {
  TENANT
  OWNER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}


enum PropertyType {
  APARTMENT
  HOUSE
  STUDIO
  VILLA
  PG
}

enum PropertyStatus {
  ACTIVE
  INACTIVE
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  age           Int?      // Nullable because Google OAuth does not provide age by default.
  image         String?
  emailVerified DateTime?
  passwordHash  String?   // Nullable because Google users may not have password login.
  role          UserRole  @default(TENANT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  properties    Property[] // Owner relationship for property module.

  bookings Booking[] @relation("TenantBookings")

}


model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId]) 
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model AuthRateLimit{
  key String @id
  scope String
  attempts Int @default(0)
  windowStart DateTime
  blockedUntil DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scope])
  @@index([blockedUntil])

}

model Property {
  id               String         @id @default(cuid())
  ownerId           String
  title             String
  description       String         @db.Text
  city              String
  state             String
  country           String         @default("India")
  addressLine1      String
  addressLine2      String?
  postalCode        String
  type              PropertyType
  bedrooms          Int
  bathrooms         Int
  areaSqft          Int?
  monthlyRent       Decimal        @db.Decimal(10, 2)
  securityDeposit   Decimal?       @db.Decimal(10, 2)
  imageUrls         Json?

  availableFrom     DateTime
  status            PropertyStatus @default(ACTIVE)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([city, status])
  @@index([monthlyRent])
  @@index([availableFrom])

  bookings Booking[]

}

model Booking {
  id            String        @id @default(cuid())
  propertyId    String
  tenantId      String
  checkIn       DateTime
  checkOut      DateTime
  guests        Int           @default(1)
  nights        Int
  pricePerNight Decimal       @db.Decimal(10, 2)
  totalAmount   Decimal       @db.Decimal(10, 2)
  status        BookingStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant   User     @relation("TenantBookings", fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([propertyId, checkIn, checkOut])
  @@index([tenantId, createdAt])

  payment Payment?
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

model Payment {
  id                String        @id @default(cuid())
  bookingId         String        @unique
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("INR")
  razorpayOrderId   String        @unique
  razorpayPaymentId String?       @unique
  razorpaySignature String?       @db.Text
  status            PaymentStatus @default(PENDING)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}
